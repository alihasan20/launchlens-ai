generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum StartupStage {
  IDEA
  MVP
  EARLY_STAGE
  GROWTH
}

enum StartupStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  hashedPassword   String
  image            String?
  role             UserRole      @default(USER)

  startupIdeas     StartupIdea[]

  accounts Account[]
  sessions Session[]  

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model StartupIdea {
  id               String          @id @default(cuid())

  title            String
  description      String
  problem          String
  solution         String

  industry         String
  stage            StartupStage
  status           StartupStatus   @default(ACTIVE)

  tags             String[]

  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  aiReport         AIReport?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model AIReport {
  id                    String        @id @default(cuid())

  validationScore       Int

  marketAnalysis        String
  competitorAnalysis    String
  swotAnalysis          String
  businessModel         String
  mvpPlan               String
  goToMarketStrategy    String
  risks                 String
  roadmap               String
  investorPitch         String

  startupIdeaId         String        @unique
  startupIdea           StartupIdea   @relation(fields: [startupIdeaId], references: [id], onDelete: Cascade)

  createdAt             DateTime      @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}